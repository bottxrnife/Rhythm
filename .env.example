## Expo / React Native app environment
## Copy to `.env` and fill in your values.

# Local verification server (run `python3 backend/local_server.py`)
EXPO_PUBLIC_VERIFY_URL=http://<YOUR_LAN_IP>:3001/verify

# Solana cluster for wallet authorize + RPC + explorer links
# Allowed: devnet | mainnet-beta
EXPO_PUBLIC_SOLANA_CLUSTER=devnet

